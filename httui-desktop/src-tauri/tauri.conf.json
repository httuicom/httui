{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "httui",
  "version": "0.1.0",
  "identifier": "com.notes.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev --prefix ..",
    "beforeBuildCommand": "npm run build --prefix .."
  },
  "app": {
    "windows": [
      {
        "title": "httui",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' asset: https: data: blob:; connect-src 'self' ipc: http://ipc.localhost http://localhost:*; font-src 'self' data: https://fonts.gstatic.com",
      "dangerousDisableAssetCspModification": true,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$APPDATA/**", "$HOME/**"],
          "deny": ["$HOME/.ssh/**", "$HOME/.gnupg/**", "$HOME/.aws/**", "$HOME/.config/gcloud/**"]
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZEQkZGMEM4NjU1QUE5RUYKUldUdnFWcGx5UEMvL2JSdUY0QTlFQ3h1MkdCc1pUWnFDUVNuQzVsVnpTQ2hkN2hGSXN5ci9lcUkK",
      "endpoints": [
        "https://github.com/httuicom/httui/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/claude-sidecar.mjs"]
  }
}
